{
  "apiVersion": 1,
  "commands": [
    { "id": "pier.codex.addAccount", "title": "Codex: Add Account" },
    { "id": "pier.codex.switchAccount", "title": "Codex: Switch Account" },
    { "id": "pier.codex.refreshUsage", "title": "Codex: Refresh Usage" }
  ],
  "configuration": {
    "properties": {
      "pier.codex.confirmSwitch": {
        "default": true,
        "description": "Show a confirmation dialog before switching the active Codex account.",
        "order": 10,
        "type": "boolean"
      }
    }
  },
  "dataSchemas": {
    "codex.accounts": { "read": ">=1 <=1", "write": 1 }
  },
  "description": "Codex account management and usage monitoring for Pier.",
  "engines": { "pier": ">=0.1.0 <0.2.0" },
  "id": "pier.codex",
  "locales": {
    "zh-CN": {
      "name": "Codex 账户管理",
      "description": "管理 Codex 账号,登录、切换、观测用量。",
      "commands": {
        "pier.codex.addAccount": { "title": "Codex: 添加账号" },
        "pier.codex.switchAccount": { "title": "Codex: 切换账号" },
        "pier.codex.refreshUsage": { "title": "Codex: 刷新用量" }
      },
      "missionControlWidgets": {
        "pier.codex.accounts": {
          "title": "Codex 账号",
          "description": "管理 Codex 账号和观测用量。"
        }
      },
      "settings": {
        "pier.codex.confirmSwitch": {
          "label": "切换账号前弹窗确认",
          "description": "切换到其他 Codex 账号前先弹一个确认对话框。"
        }
      }
    }
  },
  "main": "dist/main.js",
  "missionControlWidgets": [
    {
      "category": "agent",
      "defaultSize": { "w": 4, "h": 4 },
      "description": "Manage Codex accounts and monitor usage.",
      "id": "pier.codex.accounts",
      "searchTerms": ["codex", "account", "usage", "账号", "用量"],
      "maxSize": { "w": 8, "h": 10 },
      "minSize": { "w": 3, "h": 3 },
      "title": "Codex Accounts"
    }
  ],
  "name": "Codex Account Management",
  "panels": [],
  "permissions": ["plugin:read"],
  "publisher": "Pier",
  "renderer": "dist/renderer.js",
  "terminalStatusItems": [],
  "version": "1.0.1"
}
