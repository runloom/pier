{
  "apiVersion": 1,
  "commands": [
    { "id": "pier.codex.addAccount", "title": "Codex: Add Account" },
    { "id": "pier.codex.switchAccount", "title": "Codex: Switch Account" },
    { "id": "pier.codex.refreshUsage", "title": "Codex: Refresh Usage" }
  ],
  "configuration": {
    "properties": {
      "pier.codex.confirmSwitch": {
        "default": true,
        "description": "Show a confirmation dialog before switching the active Codex account.",
        "order": 10,
        "type": "boolean"
      }
    }
  },
  "dashboardWidgets": [
    {
      "defaultSize": { "w": 4, "h": 4 },
      "description": "Manage Codex accounts and monitor usage.",
      "id": "pier.codex.accounts",
      "maxSize": { "w": 8, "h": 10 },
      "minSize": { "w": 3, "h": 3 },
      "title": "Codex Accounts"
    }
  ],
  "dataSchemas": {
    "codex.accounts": { "read": ">=1 <=1", "write": 1 }
  },
  "description": "管理 Codex 账号，登录、切换、观测用量。",
  "engines": { "pier": ">=0.1.0 <0.2.0" },
  "id": "pier.codex",
  "main": "dist/main.js",
  "name": "Codex 账户管理",
  "panels": [],
  "permissions": ["plugin:read"],
  "publisher": "Pier",
  "renderer": "dist/renderer.js",
  "terminalStatusItems": [],
  "version": "1.0.0"
}
