{
  "name": "@pier/plugin-grok",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:main": "vite build --config vite.config.main.ts",
    "build:renderer": "vite build --config vite.config.renderer.ts",
    "dev:main": "vite build --config vite.config.main.ts --watch",
