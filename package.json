{
  "name": "pier",
  "version": "0.1.0",
  "description": "Pier — 本地 AI 开发工作台（dockview panel 布局 + 终端 + 代码变更预览 + 多 agent 状态可见性）",
  "type": "module",
  "main": "out/main/index.js",
  "private": true,
  "bin": {
    "pier": "./bin/pier.mjs"
  },
  "license": "TBD",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "typecheck": "pnpm typecheck:host && pnpm typecheck:packages",
    "typecheck:host": "tsc --noEmit",
    "typecheck:packages": "tsc -p packages/ui/tsconfig.json --noEmit && tsc -p packages/plugin-api/tsconfig.json --noEmit && tsc -p packages/plugin-codex/tsconfig.json --noEmit",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "format": "ultracite fix",
    "format:check": "ultracite check",
    "depcruise": "depcruise --config dependency-cruiser.config.cjs src packages",
    "check:file-size": "bash scripts/check-file-size.sh",
    "build:libghostty": "bash scripts/build-libghostty.sh",
    "build:native": "cd native && bash build.sh",
    "build:icons": "node ./scripts/build-app-icons.mjs",
    "plugin:codex:build": "pnpm --filter @pier/plugin-codex build",
    "plugin:codex:pack": "pnpm --filter @pier/plugin-codex build:package",
    "plugins:pack": "pnpm -r --filter '@pier/plugin-*' --workspace-concurrency=1 run build:package",
    "plugins:index": "node ./scripts/generate-plugin-index.mjs",
    "pricing:update": "node ./scripts/update-model-pricing.mjs",
    "check:plugin-index": "pnpm plugins:pack && node scripts/verify-plugin-index-assets.mjs --source=release",
    "check:static": "pnpm typecheck && pnpm lint && pnpm depcruise && pnpm check:file-size",
    "check": "pnpm check:static && pnpm test:unit && pnpm test:component && pnpm test:integration",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:integration": "vitest run tests/integration",
    "test:native": "swift test --package-path native",
    "pretest:e2e": "pnpm plugin:codex:pack",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:coverage": "vitest run --coverage --no-file-parallelism",
    "predev": "pnpm plugin:codex:pack && node ./scripts/dev-profile.mjs predev",
    "dev": "node ./scripts/dev-with-plugins.mjs",
    "dev:host": "node ./scripts/dev-profile.mjs electron-dev",
    "dev:info": "node ./scripts/dev-profile.mjs info",
    "cli:dev": "node ./bin/pier.mjs",
    "electron:dev": "pnpm dev",
    "electron:preview": "electron-vite preview",
    "build:electron": "electron-vite build && node scripts/check-preload-bundle.mjs",
    "build:native:universal": "NATIVE_ARCHS=\"arm64 x86_64\" pnpm build:native",
    "build:dist": "bash scripts/build-dist.sh",
    "build": "pnpm build:electron",
    "setup:worktree": "node ./scripts/setup-worktree.mjs",
    "bootstrap": "bash scripts/bootstrap.sh",
    "prepare": "husky && node scripts/husky-trim.mjs",
    "postinstall": "node ./scripts/ensure-electron.mjs"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "6.0.3",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-go": "6.0.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lang-python": "6.2.1",
    "@codemirror/lang-rust": "6.0.2",
    "@codemirror/lang-xml": "6.1.0",
    "@codemirror/lang-yaml": "6.1.3",
    "@codemirror/language": "6.12.4",
    "@codemirror/legacy-modes": "6.5.3",
    "@codemirror/search": "6.7.1",
    "@codemirror/state": "6.7.1",
    "@hookform/resolvers": "5.4.0",
    "@leeoniya/ufuzzy": "1.0.19",
    "@lezer/highlight": "1.2.3",
    "@pier/plugin-api": "workspace:*",
    "@pier/ui": "workspace:*",
    "@pierre/theme": "^1.1.0",
    "@shikijs/themes": "^4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "6.0.2",
    "dockview-react": "7.0.2",
    "electron-updater": "6.8.9",
    "embla-carousel-react": "^8.6.0",
    "es-module-lexer": "1.5.4",
    "i18next": "^26.3.1",
    "input-otp": "^1.4.2",
    "lucide-react": "1.21.0",
    "minimatch": "10.2.5",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-grid-layout": "^2.2.3",
    "react-hook-form": "7.80.0",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "semver": "7.6.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tar-stream": "3.1.7",
    "vaul": "^1.1.2",
    "write-file-atomic": "^8.0.0",
    "zod": "4.4.3",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "1.61.0",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/semver": "7.5.8",
    "@types/tar-stream": "3.1.3",
    "@types/write-file-atomic": "^4.0.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "dependency-cruiser": "17.4.3",
    "electron": "42.4.0",
    "electron-builder": "26.15.2",
    "electron-vite": "5.0.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.7",
    "playwright": "1.61.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "ultracite": "7.8.3",
    "vite": "8.0.16",
    "vitest": "4.1.10"
  },
  "$pin-policy": "exact pin 到 install 当日 latest stable; 不用 latest 字面; 升级走 plan unlock",
  "$peer-policy": "electron-vite 5 已通过本仓 build 验证可配 Vite 8；上游 peer range 尚未包含 Vite 8，按包对精确放行并由 pnpm build 守护。"
}
