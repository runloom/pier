{
  "name": "pier",
  "version": "0.1.0",
  "description": "Pier — 本地 AI 开发工作台（dockview panel 布局 + 终端 + 代码变更预览 + 多 agent 状态可见性）",
  "type": "module",
  "main": "out/main/index.js",
  "private": true,
  "bin": {
    "pier": "./bin/pier.mjs"
  },
  "license": "TBD",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "format": "ultracite fix",
    "format:check": "ultracite check",
    "depcruise": "depcruise --config dependency-cruiser.config.cjs src packages",
    "check:file-size": "bash scripts/check-file-size.sh",
    "build:libghostty": "bash scripts/build-libghostty.sh",
    "build:native": "cd native && bash build.sh",
    "build:icons": "node ./scripts/build-app-icons.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm depcruise && pnpm check:file-size && pnpm test:unit && pnpm test:component",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:coverage": "vitest run --coverage",
    "predev": "node ./scripts/dev-profile.mjs predev",
    "dev": "node ./scripts/dev-profile.mjs electron-dev",
    "dev:info": "node ./scripts/dev-profile.mjs info",
    "cli:dev": "node ./bin/pier.mjs",
    "electron:dev": "node ./scripts/dev-profile.mjs electron-dev",
    "electron:preview": "electron-vite preview",
    "build:electron": "electron-vite build",
    "build:native:universal": "NATIVE_ARCHS=\"arm64 x86_64\" pnpm build:native",
    "build:dist": "bash scripts/build-dist.sh",
    "build": "pnpm build:electron",
    "setup:worktree": "node ./scripts/setup-worktree.mjs",
    "bootstrap": "bash scripts/bootstrap.sh",
    "prepare": "husky",
    "postinstall": "node ./scripts/ensure-electron.mjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "6.5.0",
    "@hookform/resolvers": "5.4.0",
    "@leeoniya/ufuzzy": "1.0.19",
    "@pier/ui": "workspace:*",
    "@pierre/theme": "^1.1.0",
    "@shikijs/themes": "^4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "6.0.2",
    "dockview-react": "6.6.1",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^26.3.1",
    "input-otp": "^1.4.2",
    "lucide-react": "1.21.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-grid-layout": "^2.2.3",
    "react-hook-form": "7.80.0",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "vaul": "^1.1.2",
    "write-file-atomic": "^8.0.0",
    "zod": "4.4.3",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "1.61.0",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/write-file-atomic": "^4.0.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "dependency-cruiser": "17.4.3",
    "electron": "42.4.0",
    "electron-builder": "26.15.2",
    "electron-vite": "5.0.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.7",
    "playwright": "1.61.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "ultracite": "7.8.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "$pin-policy": "exact pin 到 install 当日 latest stable; 不用 latest 字面; 升级走 plan unlock"
}
