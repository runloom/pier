{
  "name": "pier",
  "version": "0.0.0",
  "description": "Pier — 本地 AI 开发工作台（dockview panel 布局 + 终端 + 代码变更预览 + 多 agent 状态可见性）",
  "type": "module",
  "main": "out/main/index.js",
  "private": true,
  "license": "TBD",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "format": "ultracite fix",
    "format:check": "ultracite check",
    "depcruise": "depcruise --config dependency-cruiser.config.cjs src",
    "check:file-size": "bash scripts/check-file-size.sh",
    "check": "pnpm typecheck && pnpm lint && pnpm depcruise && pnpm check:file-size",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:coverage": "vitest run --coverage",
    "predev": "node ./scripts/dev-profile.mjs predev",
    "dev": "node ./scripts/dev-profile.mjs electron-dev",
    "dev:info": "node ./scripts/dev-profile.mjs info",
    "electron:dev": "node ./scripts/dev-profile.mjs electron-dev",
    "electron:preview": "electron-vite preview",
    "build:electron": "electron-vite build",
    "build:dist": "pnpm build:electron && electron-builder",
    "build": "pnpm build:electron",
    "setup:worktree": "node ./scripts/setup-worktree.mjs",
    "prepare": "husky",
    "postinstall": "node ./scripts/ensure-electron.mjs"
  },
  "dependencies": {
    "@pierre/theme": "^1.0.3",
    "@shikijs/themes": "^4.2.0",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "dockview-react": "6.6.1",
    "i18next": "^26.3.1",
    "lucide-react": "1.21.0",
    "proper-lockfile": "^4.1.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "write-file-atomic": "^8.0.0",
    "zod": "4.4.3",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "1.61.0",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.3",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/write-file-atomic": "^4.0.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "dependency-cruiser": "17.4.3",
    "electron": "42.4.0",
    "electron-builder": "26.15.2",
    "electron-vite": "5.0.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.7",
    "playwright": "1.61.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "ultracite": "7.8.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "$pin-policy": "exact pin 到 install 当日 latest stable; 不用 latest 字面; 升级走 plan unlock"
}
