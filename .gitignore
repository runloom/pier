.DS_Store
node_modules
# build/ 默认忽略; 但 electron-builder buildResources (icon.*, entitlements) 必须入库.
/build/*
!/build/icon.icns
!/build/icon.ico
!/build/icon.png
!/build/app-icon-master.svg
!/build/app-icon-rounded.svg
!/build/design-sources/
!/build/entitlements.mac.plist
/package
.env
.env.*
!.env.example
electron-builder.env
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.playwright-mcp/
.omc/
