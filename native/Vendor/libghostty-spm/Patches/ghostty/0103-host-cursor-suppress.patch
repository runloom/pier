+/// Callback to set host-forced cursor suppression. When suppressed the
+/// renderer never draws the cursor glyph regardless of terminal mode or
+/// focus. Used by embedders whose own input UI overlays the terminal.
+pub fn hostCursorSuppressCallback(self: *Surface, suppressed: bool) !void {
+    // Crash metadata in case we crash in here
+    crash.sentry.thread_state = self.crashThreadState();
+    defer crash.sentry.thread_state = null;
+
+    _ = self.renderer_thread.mailbox.push(.{
+        .host_cursor_suppress = suppressed,
+    }, .{ .forever = {} });
+    try self.queueRender();
+}
