# Pier 环境变量
# dev 本地可拷贝为 .env.local；electron-builder release 可拷贝为 electron-builder.env。

# === macOS notarize (release 用) ===
# App Store Connect API key notarization (recommended)
APPLE_API_KEY=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=

# Alternative: Apple ID notarization
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# Alternative: notarytool keychain profile
APPLE_KEYCHAIN_PROFILE=
APPLE_KEYCHAIN=

# macOS code signing
CSC_NAME=
CSC_LINK=
CSC_KEY_PASSWORD=

# === Windows code sign (release 用) ===
WIN_CSC_LINK=
WIN_CSC_KEY_PASSWORD=

# === GitHub release ===
GH_TOKEN=
