# Pier 环境变量
# 复制为 electron-builder.env（gitignored）后填写。
#   cp electron-builder.env.example electron-builder.env
#
# 正式分发最小集：
#   1. Keychain 有 "Developer ID Application: <Name> (<TEAM_ID>)"
#   2. 下面 notarize 三选一
#   3. pnpm build:dist
#
# 本机调试（不可分发）：
#   pnpm build:dist --allow-dev-sign --no-notarize

# === macOS code signing ===
# 推荐不填 CSC_NAME：build-dist.sh 会自动钉死 Developer ID Application。
# 多证书时再显式指定 qualifier（不要带 "Developer ID Application:" 前缀；含括号须引号）：
# CSC_NAME='Your Name (TEAMID12AB)'
CSC_NAME=
# CSC_LINK=/absolute/path/to/certs.p12
# CSC_KEY_PASSWORD=...
CSC_LINK=
CSC_KEY_PASSWORD=

# === macOS notarize (release 用，三选一) ===
# 1) notarytool keychain profile（本机推荐）
#    xcrun notarytool store-credentials pier-notarize \
#      --apple-id "you@example.com" --team-id TEAMID12AB
#    # 密码处贴 appleid.apple.com 生成的 app-specific password
APPLE_KEYCHAIN_PROFILE=
APPLE_KEYCHAIN=
APPLE_TEAM_ID=

# 2) App Store Connect API key
APPLE_API_KEY=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=

# 3) Apple ID + app-specific password
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=

# === Windows code sign (release 用) ===
WIN_CSC_LINK=
WIN_CSC_KEY_PASSWORD=

# === GitHub release ===
GH_TOKEN=
